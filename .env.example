# ─── Chrome Extension ──────────────────────
# Secret key sent by the PrionVault Chrome extension in X-PrionVault-Key header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable extension API access.
PRIONVAULT_EXTENSION_API_KEY=

# ─── Core (required) ───────────────────────
# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=

# PostgreSQL connection string (Railway injects DATABASE_URL automatically).
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Public base URL of the app, used for absolute links in emails.
APP_URL=https://your-app.up.railway.app

# Local data directory for CSVs, cache and logs (defaults to ./data in dev).
# DATA_DIR=/data

# ─── Authentication ────────────────────────
ADMIN_PASSWORD=

# ─── Contact ───────────────────────────────
CONTACT_EMAIL=

# ─── Dropbox ───────────────────────────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# ─── PrionVault ingest queue ───────────────
# Where PDFs uploaded via the Ingest queue live until the worker
# processes them. If unset, the code prefers /data/prionvault_staging
# (Railway persistent volume), falling back to a temp dir.
# Set this only to override the auto-detected location.
# PRIONVAULT_STAGING_DIR=/data/prionvault_staging

# ─── PrionVault auto-scan daemon ───────────
# Every N hours a background thread scans the Dropbox watch folder
# for new PDFs and enqueues them via the same pipeline the
# "Scan Dropbox folder" button uses. Multi-worker safe via a DB
# lease (table prionvault_scheduled_runs, migration 025).
#
# All optional — defaults work for the standard Railway deploy:
# PRIONVAULT_AUTO_SCAN_DISABLED=1       # turn off entirely
# PRIONVAULT_AUTO_SCAN_INTERVAL_HOURS=6 # how often to scan
# PRIONVAULT_AUTO_SCAN_FOLDER=/PrionLab tools/PDFs
# PRIONVAULT_AUTO_SCAN_BATCH_LIMIT=500  # max PDFs per scan run
# PRIONVAULT_AUTO_SCAN_POLL_SECONDS=900 # how often the daemon checks

# ─── Postgres backup → Dropbox ─────────────
# Folder inside Dropbox where pg_dump backups are mirrored. Default:
#   /PrionLab tools/Backups
# Triggered manually from Admin → Database, or by the scheduled
# systemd timer in deploy/systemd/ (see RESTORE.md for restore steps).
PRIONLAB_BACKUP_DIR=/PrionLab tools/Backups
# How many recent daily backups to keep in Dropbox.
PRIONLAB_BACKUP_RETAIN_DAILY=90
# Plus the first-of-month backup for each of the last N months.
PRIONLAB_BACKUP_RETAIN_MONTHLY=24

# ─── SMTP ──────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Options: tls | ssl | none
SMTP_SECURE=tls

# ─── PrionPacks scheduled backup ───────────
# How often to back up PrionPacks data to Dropbox (hours, default 24).
# PRIONPACKS_BACKUP_INTERVAL_HOURS=24
# How many backups to keep (default 30).
# PRIONPACKS_BACKUP_RETENTION=30

# ─── Redis (optional) ──────────────────────
# Used by Flask-Limiter for distributed rate limiting across workers.
# Falls back to in-memory storage when unset (fine for single-worker).
# REDIS_URL=redis://localhost:6379/0

# ─── External APIs (optional) ──────────────
# Scopus API key — enables citation and author lookup in PrionVault.
# SCOPUS_API_KEY=

# SerpAPI key — enables Google Scholar search in AI assistant.
# SERPAPI_KEY=

# ─── Sentry (error reporting) ──────────────
# A Sentry DSN is a public key — safe to ship to the browser, so this
# same value drives BOTH the Flask backend SDK (app.py) AND the
# browser-side SDK loaded by every base.html-rendered page.
# Unset → both are no-ops (local dev / unconfigured envs stay quiet).
SENTRY_DSN=
# Tag attached to every event; usually "production" or "staging".
SENTRY_ENVIRONMENT=production
