# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Sentry — browser-side error reporting. The DSN is a public key,
# safe to expose to the bundle; we tag every event with
# `service: prionread-frontend` (see src/main.jsx) so events here
# stay distinguishable from the Node backend and the Flask service
# in the same Sentry project. Unset → no-op (the init in main.jsx
# only fires when VITE_SENTRY_DSN is set at build time).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
# Optional — Railway/Vercel build environments usually expose the
# commit SHA. Wire it in your build step (Railway: $RAILWAY_GIT_COMMIT_SHA)
# so Sentry can tie events to the deploy that produced them.
VITE_SENTRY_RELEASE=
