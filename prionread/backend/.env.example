# Database
DATABASE_URL=

# Authentication
JWT_SECRET=

# Dropbox integration
DROPBOX_REFRESH_TOKEN=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# OpenAI (optional — AI summary generation)
OPENAI_API_KEY=

# App
# IMPORTANT: set this to the Flask host URL (without trailing slash).
# Email login links will be broken if this is empty.
# Example: FRONTEND_URL=https://web-production-5517e.up.railway.app
FRONTEND_URL=
PORT=3001

# Scheduled tasks (set to true in production to enable cron jobs)
ENABLE_CRON=false

# Sentry — error reporting for the Node backend (Express + cron).
# A Sentry DSN is a public key, so the same value can be reused
# across services. Tagged `service: prionread-backend` so events
# stay distinguishable from the Flask backend and the React app
# in the same project. Cron-job failures also flow through here
# (see notificationService.js → _reportCronError). Unset → no-op.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
